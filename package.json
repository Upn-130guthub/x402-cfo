{
  "name": "tollbooth",
  "version": "0.1.0",
  "description": "Agent financial controller for x402 payments. Budget enforcement, cost policies, spend ledger, and analytics for AI agents.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": ["dist", "README.md", "LICENSE"],
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch examples/demo/server.ts",
    "example": "tsx examples/basic/server.ts",
    "test": "node --test --import tsx tests/budget.test.ts tests/policy.test.ts tests/controller.test.ts",
    "prepublishOnly": "npm run build"
  },
  "keywords": ["x402", "402", "paywall", "micropayments", "stablecoin", "USDC", "middleware", "express", "agentic", "ai-agent", "coinbase"],
  "license": "MIT",
  "peerDependencies": {
    "express": ">=4.0.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.1",
    "@types/node": "^24.5.2",
    "cors": "^2.8.5",
    "@types/cors": "^2.8.17",
    "express": "^4.21.2",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2"
  }
}
